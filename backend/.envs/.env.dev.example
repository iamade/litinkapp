# KAN-264: Dev media path isolation
# Copy this to .env.dev and fill in real values
MINIO_BUCKET_NAME=litinkai-dev
MINIO_ENDPOINT=http://litink-dev-minio:9000
MINIO_PUBLIC_URL=http://localhost:9010
# DEV does not call external providers — leave these unset:
# MINIO_PROVIDER_PUBLIC_URL=
# MODELSLAB_MEDIA_PUBLIC_URL=
# All other vars: copy from .env.local (API keys, DB creds, etc.)
