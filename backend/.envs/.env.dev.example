# KAN-264 / KAN-402: Dev media path isolation
# Copy this to .env.dev and fill in real values.
# Dev endpoint is internal Docker network; public URLs are browser/provider-facing.
MINIO_BUCKET_NAME=litinkai-dev
MINIO_ENDPOINT=http://litink-dev-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Browser/public URL for the local dev MinIO console or local proxy (no bucket name).
MINIO_PUBLIC_URL=http://localhost:9010
# Dev does not call external providers by default — uncomment only if you need provider
# fetch-back from the dev MinIO instance, and ensure it is externally reachable.
# MINIO_PROVIDER_PUBLIC_URL=http://localhost:9010
# MODELSLAB_MEDIA_PUBLIC_URL=http://localhost:9010
# All other vars: copy from .env.local (API keys, DB creds, etc.)
# KAN-401 script/free fallback providers
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
Z_AI_FREE_MODEL=glm-5.2
PIAPI_API_KEY_LITINKAI=
PIAPI_BASE_URL=https://api.piapi.ai/v1
PIAPI_FREE_MODEL=gpt-4o-mini
FEATHERLESS_API_KEY_LITINKAI=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_FREE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
