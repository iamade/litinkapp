# =============================================================================
# VPS-Staging Environment — Mac dev → VPS staging API via Traefik
# All service hosts point to vps-staging-* container names on vps_staging_nw
#
# Copy this file to backend/.envs/.env.vps-staging and fill in real values.
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG=True

PROJECT_NAME="LitInk-Ai"
PROJECT_DESCRIPTION="Welcome to the next generation of learning and entertainment"
API_V1_STR="/api/v1"
SUPPORT_EMAIL="support@litinkai.com"
SITE_NAME="Lit-Ink Ai"
VERSION="1.0.0"

# Security
API_BASE_URL="https://staging.litinkai.local"
JWT_SECRET_KEY=change-me-to-a-real-secret
SIGNING_KEY=change-me-to-a-real-signing-key

# Postgres DB — VPS-side: points to vps-staging-postgres container
POSTGRES_USER=litink
POSTGRES_PASSWORD=change-me
POSTGRES_DB=litinkapp
POSTGRES_HOST=vps-staging-postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://litink:change-me@vps-staging-postgres:5432/litinkapp

# Redis — VPS-side: points to vps-staging-redis container
REDIS_URL=redis://vps-staging-redis:6379

# AI Services
OPENAI_API_KEY=sk-your-openai-key
ELEVENLABS_API_KEY=sk-your-elevenlabs-key
TAVUS_API_KEY=your-tavus-key

# Blockchain
ALGORAND_TOKEN=your-algorand-token
ALGORAND_SERVER=https://testnet-api.4160.nodely.io
ALGORAND_INDEXER=https://testnet-idx.4160.nodely.io
CREATOR_MNEMONIC=your_creator_account_mnemonic_here

# Celery — VPS-side: points to vps-staging-redis container
CELERY_FLOWER_USER="admin"
CELERY_FLOWER_PASSWORD="change-me"
CELERY_BROKER_URL="redis://vps-staging-redis:6379/1"
CELERY_RESULT_BACKEND="redis://vps-staging-redis:6379/1"
CELERY_TASK_DEFAULT_QUEUE="litink_staging_tasks"

# CORS
ALLOWED_HOSTS=["http://localhost:3000", "http://localhost:5173", "https://localhost:5173", "http://localhost:5174", "https://staging.litinkai.local"]

# Kling API
KLINGAI_ACCESS_KEY_ID=your-kling-key-id
KLINGAI_ACCESS_KEY_SECRET=your-kling-key-secret

GOOGLE_AI_STUDIO_API_KEY=your-google-ai-key

MODELSLAB_API_KEY=your-modelslab-key
MODELSLAB_BASE_URL=https://modelslab.com/api/v7
MODELSLAB_V6_BASE_URL=https://modelslab.com/api/v6

DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Email Configuration
MAIL_FROM="noreply@litinkai.com"
MAIL_FROM_NAME="Litink AI"

MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
MAILGUN_SENDER_EMAIL=noreply@litinkai.com
MAILGUN_SMTP_SERVER=smtp.mailgun.org

# SMTP — VPS-side: points to vps-staging-mailpit container
SMTP_HOST=vps-staging-mailpit
SMTP_PORT=1025

# STRIPE
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

STRIPE_BASIC_PRICE_ID=price_placeholder
STRIPE_STANDARD_PRICE_ID=price_placeholder
STRIPE_PREMIUM_PRICE_ID=price_placeholder
STRIPE_PROFESSIONAL_PRICE_ID=price_placeholder
STRIPE_ENTERPRISE_PRICE_ID=custom
STRIPE_FREE_PRICE_ID=price_placeholder
STRIPE_ACCOUNT_ID=acct_placeholder

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
REDIRECT_URIS=https://staging.litinkai.local/api/v1/auth/google

# GROQ
GROQ_API_KEY=your-groq-key

OLLAMA_API_KEY=your-ollama-key

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

OAUTH_REDIRECT_BASE_URL=https://staging.litinkai.local/api/v1

# MinIO Storage — VPS-side: points to vps-staging-minio container
USE_MINIO=true
MINIO_ENDPOINT=http://vps-staging-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=litinkai-staging
MINIO_PUBLIC_URL=https://minio-staging.litinkai.com
MINIO_PROVIDER_PUBLIC_URL=https://minio-staging.litinkai.com

MODELSLAB_MEDIA_PUBLIC_URL=https://minio-staging.litinkai.com
