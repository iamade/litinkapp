# Dev environment template — uses VPS tunneled services
# Copy to scripts/env.dev, then run your dev/tunnel workflow.
# Do not commit real credentials in scripts/env.dev.

DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@127.0.0.1:5433/<db_name>
REDIS_URL=redis://127.0.0.1:6380/0
CELERY_BROKER_URL=redis://127.0.0.1:6380/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6380/0

USE_MINIO=true
MINIO_ENDPOINT=http://127.0.0.1:9010
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET_NAME=<minio_bucket_name>
MINIO_PUBLIC_URL=http://127.0.0.1:9010

# Frontend
VITE_API_URL=http://localhost:8001
