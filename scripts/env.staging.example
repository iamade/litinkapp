# Staging environment template — uses VPS tunneled services
# Copy to scripts/env.staging, then copy/run via: bash scripts/start-staging.sh
# Do not commit real credentials in scripts/env.staging.

DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@127.0.0.1:5432/<db_name>
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

USE_MINIO=true
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET_NAME=<minio_bucket_name>
MINIO_PUBLIC_URL=http://127.0.0.1:9000

# Frontend
VITE_API_URL=http://localhost:8000
