# Staging environment template — uses VPS tunneled services
# Copy to scripts/env.staging, then copy/run via: bash scripts/start-staging.sh
# Do not commit real credentials in scripts/env.staging.

# Docker containers reach host-machine SSH tunnels via host.docker.internal
POSTGRES_DB=<db_name>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@host.docker.internal:5432/<db_name>

REDIS_URL=redis://host.docker.internal:6379/0
CELERY_BROKER_URL=redis://host.docker.internal:6379/0
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/0

USE_MINIO=true
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET_NAME=<minio_bucket_name>
MINIO_PUBLIC_URL=http://127.0.0.1:9000

# Email / Mailpit local tunnel defaults
MAIL_FROM=noreply@litinkai.com
MAIL_FROM_NAME=LitInkAI Staging Local
SMTP_HOST=mailpit
SMTP_PORT=1025

# Frontend
VITE_API_URL=http://localhost:8000
