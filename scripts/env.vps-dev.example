# VPS dev tunnel environment template
# Copy real values to backend/.envs/.env.local.vps-dev.
# Do not commit real credentials.

# Docker containers reach host-machine SSH tunnels via host.docker.internal
POSTGRES_DB=<db_name>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@host.docker.internal:5433/<db_name>

REDIS_URL=redis://host.docker.internal:6380/0
CELERY_BROKER_URL=redis://host.docker.internal:6380/0
CELERY_RESULT_BACKEND=redis://host.docker.internal:6380/0

USE_MINIO=true
MINIO_ENDPOINT=http://host.docker.internal:9010
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET_NAME=<minio_bucket_name>
MINIO_PUBLIC_URL=http://127.0.0.1:9010

# Email / Mailpit dev defaults
MAIL_FROM=noreply@litinkai.com
MAIL_FROM_NAME=Litink AI
SMTP_HOST=mailpit
SMTP_PORT=1025

# Frontend
VITE_API_URL=http://localhost:8000
